.home .bg::before {
  content: "";
  position: absolute;
  top: 60%;
  right: 0%;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(245, 247, 250, 0) 0%, #f5f7fa 100%);
}
.home .history {
  max-height: 133rpx;
  overflow: hidden;
}
.home .search {
  box-shadow: 0rpx 4rpx 32rpx 0rpx rgba(0, 0, 0, 0.06);
}
.home .area-item {
  height: 68rpx;
  line-height: 68rpx;
}
.home .active {
  border: 2rpx solid #ee2233;
}